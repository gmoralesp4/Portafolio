---
export interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'left' } = Astro.props;
---

<div class={`mb-10 ${align === 'center' ? 'text-center' : ''}`}>
  <h2 class="text-3xl sm:text-4xl font-bold text-slate-50">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-3 text-lg text-slate-400 max-w-2xl">
        {subtitle}
      </p>
    )
  }
</div>
