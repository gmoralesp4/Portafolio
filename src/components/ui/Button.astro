---
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  target?: string;
  id?: string;
}

const { href, variant = 'primary', size = 'md', target, id } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:ring-offset-2 focus:ring-offset-surface-950';

const variantClasses = {
  primary: 'bg-cyan-400/10 text-cyan-400 border border-cyan-400/30 hover:bg-cyan-400/20 hover:border-cyan-400/50 hover:shadow-lg hover:shadow-cyan-400/10',
  secondary: 'bg-slate-800 text-slate-200 border border-slate-700/50 hover:bg-slate-700 hover:text-slate-100 hover:border-slate-600',
  ghost: 'text-slate-400 hover:text-slate-100 hover:bg-slate-800/50',
};

const sizeClasses = {
  sm: 'px-3 py-1.5 text-xs gap-1.5',
  md: 'px-4 py-2 text-sm gap-2',
  lg: 'px-6 py-3 text-base gap-2.5',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]}`;
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined} id={id}>
      <slot />
    </a>
  ) : (
    <button class={classes} id={id}>
      <slot />
    </button>
  )
}
