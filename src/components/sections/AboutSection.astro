---
import { getCV } from '@lib/utils';
import ScrollReveal from '@components/ui/ScrollReveal.astro';

const cv = getCV();
const { personalInfo } = cv;
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3 space-y-6">
          <div class="flex items-center gap-2 text-cyan-400 text-sm font-mono mb-4">
            <span class="w-8 h-px bg-cyan-400/50" />
            <span>Sobre Mí</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold text-slate-50">
            {personalInfo.preferredName}
          </h1>
          <div class="space-y-4 text-slate-400 leading-relaxed">
            <p>{personalInfo.summary}</p>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 space-y-4">
            <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider">Información</h3>
            <div class="space-y-3">
              <div>
                <span class="text-xs text-slate-500 uppercase tracking-wider">Email</span>
                <p class="text-sm text-slate-200 mt-0.5">
                  <a href={`mailto:${personalInfo.email}`} class="hover:text-cyan-400 transition-colors">{personalInfo.email}</a>
                </p>
              </div>
              <div>
                <span class="text-xs text-slate-500 uppercase tracking-wider">Teléfono</span>
                <p class="text-sm text-slate-200 mt-0.5">{personalInfo.phone}</p>
              </div>
              <div>
                <span class="text-xs text-slate-500 uppercase tracking-wider">Ubicación</span>
                <p class="text-sm text-slate-200 mt-0.5">{personalInfo.location}</p>
              </div>
              <div>
                <span class="text-xs text-slate-500 uppercase tracking-wider">LinkedIn</span>
                <p class="text-sm text-slate-200 mt-0.5">
                  <a href={personalInfo.linkedin} target="_blank" class="hover:text-cyan-400 transition-colors">Ver perfil</a>
                </p>
              </div>
              <div>
                <span class="text-xs text-slate-500 uppercase tracking-wider">GitHub</span>
                <p class="text-sm text-slate-200 mt-0.5">
                  <a href={personalInfo.github} target="_blank" class="hover:text-cyan-400 transition-colors">Ver repositorios</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
