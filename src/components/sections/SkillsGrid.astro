---
import { skillGroups } from '@lib/utils';
import ScrollReveal from '@components/ui/ScrollReveal.astro';
import Badge from '@components/ui/Badge.astro';

const categoryIcons: Record<string, string> = {
  backend: '{ }',
  frontend: '</>',
  databases: 'DB',
  security: '🔒',
  cloud: '☁',
  tools: '⚙',
  domainKnowledge: '🏢',
  softSkills: '💡',
};
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <div class="flex items-center gap-2 text-cyan-400 text-sm font-mono mb-4">
        <span class="w-8 h-px bg-cyan-400/50" />
        <span>Stack</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-50 mb-6">Stack Tecnológico</h1>
      <p class="text-lg text-slate-400 mb-16 max-w-2xl">
        Lenguajes, frameworks, bases de datos, cloud y herramientas de desarrollo.
      </p>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        skillGroups.map((group, index) => (
          <ScrollReveal delay={index * 50}>
            <div class="bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 hover:border-slate-600/50 hover:shadow-lg hover:shadow-cyan-400/5 transition-all duration-300 h-full">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-lg bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center text-cyan-400 text-sm font-mono">
                  {categoryIcons[group.id] || '○'}
                </div>
                <h3 class="text-base font-semibold text-slate-200">{group.label}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {
                  group.items.map((skill) => (
                    <Badge>{skill}</Badge>
                  ))
                }
              </div>
            </div>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</section>
