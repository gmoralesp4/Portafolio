---
import { getCV, assetPath } from '@lib/utils';
import ScrollReveal from '@components/ui/ScrollReveal.astro';

const cv = getCV();
const { personalInfo } = cv;
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-2 text-cyan-400 text-sm font-mono mb-4">
          <span class="w-8 h-px bg-cyan-400/50" />
          <span>Contacto</span>
          <span class="w-8 h-px bg-cyan-400/50" />
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-50 mb-3">Contacto</h1>
        <p class="text-base text-slate-400 max-w-xl mx-auto">
          Información de contacto
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
      <ScrollReveal delay={0}>
        <a href={`mailto:${personalInfo.email}`} class="block bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 text-center hover:border-cyan-400/30 hover:shadow-lg hover:shadow-cyan-400/5 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-full bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mx-auto mb-4 group-hover:bg-cyan-400/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3 class="text-base font-semibold text-slate-200 mb-1">Email</h3>
          <p class="text-sm text-slate-400 break-all">{personalInfo.email}</p>
        </a>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <a href={personalInfo.linkedin} target="_blank" class="block bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 text-center hover:border-cyan-400/30 hover:shadow-lg hover:shadow-cyan-400/5 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-full bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mx-auto mb-4 group-hover:bg-cyan-400/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="text-cyan-400"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-slate-200 mb-1">LinkedIn</h3>
          <p class="text-sm text-slate-400">Gerson Morales</p>
        </a>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 text-center hover:border-cyan-400/30 hover:shadow-lg hover:shadow-cyan-400/5 transition-all duration-300 group h-full flex flex-col items-center justify-center">
          <div class="w-12 h-12 rounded-full bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <h3 class="text-base font-semibold text-slate-200 mb-3">Descargar CV</h3>
          <div class="flex flex-col gap-2 w-full">
            <a href={assetPath('/cv/Gerson_Morales_CV_ATS.pdf')} download="Gerson_Morales_CV_ATS.pdf" class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:ring-offset-2 focus:ring-offset-surface-950 w-full px-4 py-2 text-sm gap-2 bg-slate-800 text-slate-200 border border-slate-700/50 hover:bg-slate-700 hover:text-slate-100 hover:border-slate-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              CV ATS
            </a>
            <a href={assetPath('/cv/Gerson_Morales_CV_Visual.pdf')} download="Gerson_Morales_CV_Visual.pdf" class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:ring-offset-2 focus:ring-offset-surface-950 w-full px-4 py-2 text-sm gap-2 bg-cyan-400/10 text-cyan-400 border border-cyan-400/30 hover:bg-cyan-400/20 hover:border-cyan-400/50 hover:shadow-lg hover:shadow-cyan-400/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15l3-3 3 3"/></svg>
              CV Visual
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>


