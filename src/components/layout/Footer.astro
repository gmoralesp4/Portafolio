---
import { getCV } from '@lib/utils';
const cv = getCV();
const { personalInfo } = cv;
---

<footer class="border-t border-slate-700/30 bg-surface-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="text-lg font-bold text-slate-50">
          <span class="text-cyan-400">{'<'}</span>
          <span>{personalInfo.preferredName}</span>
          <span class="text-cyan-400">{'/>'}</span>
        </a>
        <p class="mt-3 text-sm text-slate-400 leading-relaxed">
          {personalInfo.jobTitle} — {personalInfo.location}
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider mb-3">Navegación</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">Sobre Mí</a></li>
          <li><a href="/experience" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">Experiencia</a></li>
          <li><a href="/projects" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">Proyectos</a></li>
          <li><a href="/skills" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">Habilidades</a></li>
          <li><a href="/blog" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">Blog</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider mb-3">Contacto</h3>
        <ul class="space-y-2">
          <li>
            <a href={`mailto:${personalInfo.email}`} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
              {personalInfo.email}
            </a>
          </li>
          <li>
            <a href={personalInfo.github} target="_blank" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
              GitHub
            </a>
          </li>
          <li>
            <a href={personalInfo.linkedin} target="_blank" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-slate-800 text-center">
      <p class="text-sm text-slate-500">
        &copy; {new Date().getFullYear()} {personalInfo.preferredName}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
