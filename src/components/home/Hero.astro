---
import { getCV, assetPath, pagePath } from '@lib/utils';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';

const cv = getCV();
const { personalInfo } = cv;
const totalYears = new Date().getFullYear() - 2021;
const summaryFirstPara = personalInfo.summary.split('\n\n')[0] || personalInfo.summary;
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan-400/5 via-transparent to-transparent" />
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-violet-500/5 via-transparent to-transparent" />
  <div class="absolute inset-0" style="background-image: linear-gradient(rgba(34,211,238,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(34,211,238,0.03) 1px, transparent 1px); background-size: 40px 40px;" />

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-2 text-cyan-400 text-sm font-mono">
            <span class="w-8 h-px bg-cyan-400/50" />
            <span>Backend Engineer</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-50 leading-tight">
            {personalInfo.fullName}
          </h1>
          <p class="text-xl sm:text-2xl text-cyan-400 font-medium">
            {personalInfo.jobTitle}
          </p>
          <p class="text-base text-slate-400 leading-relaxed max-w-xl">
            {personalInfo.location} — Sector financiero y asegurador
          </p>
          <p class="text-sm text-slate-500 leading-relaxed max-w-xl">
            {summaryFirstPara.slice(0, 220)}...
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <Badge variant="accent" size="md">+{totalYears} años experiencia</Badge>
          <Badge variant="accent" size="md">.NET / Java / Node.js</Badge>
          <Badge variant="accent" size="md">Oracle · SQL Server</Badge>
          <Badge variant="accent" size="md">APIs REST · SOAP</Badge>
          <Badge variant="accent" size="md">{personalInfo.location}</Badge>
          <Badge variant="accent" size="md">PCI · ISO 27000</Badge>
        </div>

        <div class="flex flex-wrap gap-3">
          <Button href={pagePath('/projects')} variant="primary" size="lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            Ver Proyectos
          </Button>
          <Button href={pagePath('/contact')} variant="secondary" size="lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Contactar
          </Button>
          <Button href={pagePath('/contact')} variant="ghost" size="lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar CV
          </Button>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <div class="w-64 h-64 sm:w-80 sm:h-80 rounded-full overflow-hidden border-2 border-cyan-400/30 shadow-2xl shadow-cyan-400/10">
            <img src={assetPath('/images/profile.webp')} alt={personalInfo.preferredName} class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-gradient-to-br from-cyan-400/20 to-violet-500/20 rounded-full blur-3xl" />
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-gradient-to-br from-violet-500/20 to-cyan-400/20 rounded-full blur-3xl" />
        </div>
      </div>
    </div>
  </div>
</section>
