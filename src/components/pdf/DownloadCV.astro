---
import { assetPath } from '@lib/utils';

---

<section class="py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-surface-900/50 backdrop-blur-md border border-slate-700/30 rounded-xl p-6 md:p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
        <div>
          <h3 class="text-lg font-semibold text-slate-50 mb-2">Descargar CV</h3>
          <p class="text-sm text-slate-400">
            Elige el formato que prefieras: ATS (compatible con sistemas de seguimiento) o Visual (diseño premium).
          </p>
        </div>
        <div class="flex flex-wrap gap-3 justify-start md:justify-end">
          <a href={assetPath('/cv/Gerson_Morales_CV_ATS.pdf')} download="Gerson_Morales_CV_ATS.pdf" class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:ring-offset-2 focus:ring-offset-surface-950 px-4 py-2 text-sm gap-2 bg-slate-800 text-slate-200 border border-slate-700/50 hover:bg-slate-700 hover:text-slate-100 hover:border-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Descargar CV ATS
          </a>
          <a href={assetPath('/cv/Gerson_Morales_CV_Visual.pdf')} download="Gerson_Morales_CV_Visual.pdf" class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:ring-offset-2 focus:ring-offset-surface-950 px-4 py-2 text-sm gap-2 bg-cyan-400/10 text-cyan-400 border border-cyan-400/30 hover:bg-cyan-400/20 hover:border-cyan-400/50 hover:shadow-lg hover:shadow-cyan-400/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M9 15l3-3 3 3"/></svg>
            Descargar CV Visual
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
