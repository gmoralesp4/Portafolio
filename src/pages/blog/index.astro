---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Blog">
  <div class="pt-24 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-xl px-4">
      <div class="w-16 h-16 rounded-full bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-50 mb-4">Blog</h1>
      <p class="text-lg text-slate-400 mb-8">
        Próximamente compartiré artículos sobre desarrollo de software, arquitectura, .NET, Angular, bases de datos y experiencias profesionales.
      </p>
      <div class="inline-flex items-center gap-2 text-sm text-slate-500 bg-surface-900/50 border border-slate-700/30 rounded-full px-4 py-2">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
        En preparación
      </div>
    </div>
  </div>
</BaseLayout>
