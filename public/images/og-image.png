<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#020617" />
      <stop offset="50%" stop-color="#0f172a" />
      <stop offset="100%" stop-color="#1e293b" />
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#22d3ee" />
      <stop offset="100%" stop-color="#8b5cf6" />
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)" />
  <rect x="0" y="0" width="1200" height="630" fill="none" stroke="url(#accent)" stroke-width="2" opacity="0.3" />
  <text x="600" y="250" font-family="Inter, system-ui, sans-serif" font-size="64" font-weight="700" fill="#f8fafc" text-anchor="middle">Gerson Morales</text>
  <text x="600" y="330" font-family="Inter, system-ui, sans-serif" font-size="32" font-weight="400" fill="#22d3ee" text-anchor="middle">Analista Programador Full Stack</text>
  <text x="600" y="400" font-family="Inter, system-ui, sans-serif" font-size="20" font-weight="300" fill="#94a3b8" text-anchor="middle">.NET · Java · Oracle · Angular · Seguridad Informática</text>
  <rect x="540" y="470" width="120" height="4" rx="2" fill="url(#accent)" />
</svg>
