  </defs>
  <rect width="400" height="400" rx="200" fill="url(#bg)" stroke="url(#border)" stroke-width="3" />
  <text x="200" y="210" font-family="Inter, system-ui, sans-serif" font-size="120" font-weight="700" fill="#22d3ee" text-anchor="middle" dominant-baseline="central">GM</text>
